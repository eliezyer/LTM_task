{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rpi5-vr-task/session_config.schema.json",
  "title": "SessionConfig",
  "type": "object",
  "required": [
    "animal_id",
    "session_type",
    "num_trials",
    "iti_distribution",
    "speed_threshold_cm_s",
    "stall_timeout_s",
    "opening_corridor_length_cm",
    "context_zone_length_cm",
    "reward_zone_position_cm",
    "wheel_diameter_cm",
    "encoder_cpr"
  ],
  "properties": {
    "animal_id": {
      "type": "string",
      "minLength": 1
    },
    "session_type": {
      "type": "string",
      "enum": ["training", "retrieval", "retraining"]
    },
    "num_trials": {
      "type": "integer",
      "minimum": 1
    },
    "contexts": {
      "oneOf": [
        {
          "type": "array",
          "items": {"$ref": "#/$defs/context"}
        },
        {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/context"}
        }
      ]
    },
    "context_sequence": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1, "maximum": 255}
    },
    "task_events": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"$ref": "#/$defs/task_action"}
      }
    },
    "reward_ms_by_context": {
      "type": "object",
      "patternProperties": {
        "^[1-9][0-9]*$": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "airpuff_contexts": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1, "maximum": 255},
      "uniqueItems": true
    },
    "airpuff_duration_ms": {
      "type": "integer",
      "minimum": 1
    },
    "iti_distribution": {
      "type": "object",
      "required": ["kind", "min_s", "max_s", "mean_s"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["uniform", "truncated_exponential"]
        },
        "min_s": {"type": "number", "exclusiveMinimum": 0},
        "max_s": {"type": "number", "exclusiveMinimum": 0},
        "mean_s": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "speed_threshold_cm_s": {
      "type": "number",
      "minimum": 0
    },
    "stall_timeout_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "opening_corridor_length_cm": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "context_zone_length_cm": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "reward_zone_position_cm": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "outcome_zone_duration_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "outcome_scene_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "wheel_diameter_cm": {
      "type": "number",
      "description": "Physical running-wheel diameter in centimeters.",
      "exclusiveMinimum": 0
    },
    "encoder_cpr": {
      "type": "integer",
      "description": "Measured Teensy encoder count delta for one full physical wheel revolution.",
      "minimum": 1
    },
    "invert_encoder": {
      "type": "boolean"
    },
    "speed_alpha": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "task_status_interval_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "udp_target_ip": {
      "type": "string"
    },
    "udp_target_port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "serial_port": {
      "type": "string"
    },
    "serial_baud": {
      "type": "integer",
      "minimum": 1
    },
    "rt_hz": {
      "type": "integer",
      "minimum": 1
    },
    "ttl_pulse_width_ms": {
      "type": "integer",
      "minimum": 1
    },
    "ttl_train_gap_ms": {
      "type": "integer",
      "minimum": 0
    },
    "output_tmp_dir": {
      "type": "string"
    },
    "output_final_dir": {
      "type": "string"
    },
    "seed": {
      "type": ["integer", "null"]
    },
    "pinmap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uart_tx": {"type": "integer", "minimum": 0},
        "uart_rx": {"type": "integer", "minimum": 0},
        "water_solenoid": {"type": "integer", "minimum": 0},
        "air_solenoid": {"type": "integer", "minimum": 0},
        "wav_trial_available": {"type": "integer", "minimum": 0},
        "wav_context_1": {"type": "integer", "minimum": 0},
        "wav_context_2": {"type": "integer", "minimum": 0},
        "wav_context_3": {"type": "integer", "minimum": 0},
        "wav_cues": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "lick_input": {"type": "integer", "minimum": 0},
        "ttl_trial_start": {"type": "integer", "minimum": 0},
        "ttl_context_identity": {"type": "integer", "minimum": 0},
        "ttl_context_entry": {"type": "integer", "minimum": 0},
        "ttl_reward": {"type": "integer", "minimum": 0},
        "ttl_airpuff": {"type": "integer", "minimum": 0},
        "ttl_lick": {"type": "integer", "minimum": 0},
        "ttl_iti_start": {"type": "integer", "minimum": 0},
        "ttl_outcome_start": {"type": "integer", "minimum": 0}
      }
    }
  },
  "$defs": {
    "context": {
      "type": "object",
      "properties": {
        "id": {"type": "integer", "minimum": 1, "maximum": 255},
        "scene_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "audio_cue": {"type": "string", "minLength": 1},
        "identity_pulses": {"type": "integer", "minimum": 1},
        "reward_ms": {"type": "integer", "minimum": 0},
        "airpuff_ms": {"type": "integer", "minimum": 0},
        "outcome_events": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "task_action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "airpuff",
            "reset_segment",
            "reward",
            "start_audio",
            "stop_audio",
            "teleport",
            "ttl_pulse",
            "ttl_pulse_train"
          ]
        },
        "kind": {"type": "string"},
        "action": {"type": "string"},
        "cue": {"type": "string"},
        "cues": {
          "type": "array",
          "items": {"type": "string"}
        },
        "event": {
          "type": "string",
          "enum": [
            "trial_start",
            "context_identity",
            "context_entry",
            "reward",
            "airpuff",
            "outcome_start",
            "lick_onset",
            "iti_start"
          ]
        },
        "ttl_event": {
          "type": "string",
          "enum": [
            "trial_start",
            "context_identity",
            "context_entry",
            "reward",
            "airpuff",
            "outcome_start",
            "lick_onset",
            "iti_start"
          ]
        },
        "duration_ms": {"type": "integer", "minimum": 1},
        "pulse_count": {
          "oneOf": [
            {"type": "integer", "minimum": 1},
            {"type": "string", "enum": ["context_id", "context_identity"]}
          ]
        }
      }
    }
  }
}
